+              <Button
+                disabled={pending}
+                onClick={() => readLinearIssues("refresh")}
+                variant="ghost"
+              >
+                Refresh issue
+              </Button>
+            </>
+          ) : null}
+          {runResult?.run.status === "running" ? (
+            <Button
+              disabled={pending}
+              onClick={() => runLifecycleAction("pause")}
+              variant="outline"
+            >
+              Pause
+            </Button>
+          ) : null}
+          {runResult && !["cancelled", "failed"].includes(runResult.run.status) ? (
+            <>
+              <Button
+                disabled={pending}
+                onClick={() => runLifecycleAction("status")}
+                variant="ghost"
+              >
+                Inspect
+              </Button>
+              <Button
+                disabled={pending}
+                onClick={() => runLifecycleAction("refresh")}
+                variant="ghost"
+              >
+                Refresh
+              </Button>
+            </>
+          ) : null}
+          {runResult?.run.status === "suspended" ? (
+            <Button
+              disabled={pending}
+              onClick={() => runLifecycleAction("resume")}
+              variant="outline"
+            >
+              Resume
+            </Button>
+          ) : null}
+          {runResult && !["cancelled", "failed"].includes(runResult.run.status) ? (
+            <Button disabled={pending} onClick={cancelRun} variant="destructive">
+              Cancel
+            </Button>
+          ) : null}
+          {result?.valid ? (
+            <Button disabled={pending} onClick={run} variant="outline">
+              {pending ? <Spinner /> : null}
+              Run fixture
+            </Button>
+          ) : null}
+          <Button
+            disabled={
+              pending || !profilePath.trim() || !issueIdentifier.trim() || !issueState.trim()
+            }
+            onClick={submit}
+          >
+            {pending ? <Spinner /> : null}
+            Validate and preview
+          </Button>
+        </DialogFooter>
+      </DialogPopup>
+    </Dialog>
+  );
+});
