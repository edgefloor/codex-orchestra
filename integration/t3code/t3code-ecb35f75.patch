+        <TooltipTrigger
+          render={
+            <DialogTrigger
+              render={<Button aria-label="Automation profile" size="icon-sm" variant="ghost" />}
+            />
+          }
+        >
+          <BotIcon />
+        </TooltipTrigger>
+        <TooltipPopup>Automation profile</TooltipPopup>
+      </Tooltip>
+      <DialogPopup className="max-w-2xl">
+        <DialogHeader>
+          <DialogTitle>Automation profile</DialogTitle>
+          <DialogDescription>
