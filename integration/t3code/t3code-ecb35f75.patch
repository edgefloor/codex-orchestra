+    expectedManifestSha256,
+    ...(actual?.manifestSha256 ? { actualManifestSha256: actual.manifestSha256 } : {}),
+    detail: actual
+      ? `Orchestra Product mismatch. Missing capabilities: ${missingCapabilities.join(", ") || "none"}.`
