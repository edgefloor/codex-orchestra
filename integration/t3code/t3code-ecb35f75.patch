+  name: Schema.String,
+  kind: Schema.Literals(["string", "number", "boolean", "object", "array", "json"]),
+  required: Schema.Boolean,
+  default: Schema.optional(Schema.Json),
+});
+
+export const AutomationWorkflowPreview = Schema.Struct({
