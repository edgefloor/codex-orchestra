+                      {item.issueTitle.text}
+                      {item.issueTitle.truncated ? "…" : ""}
+                    </div>
+                    <div>
+                      {item.nextAction.text}
+                      {item.nextAction.truncated ? "…" : ""}
+                    </div>
+                    {item.claimId ? <code className="select-all">Claim {item.claimId}</code> : null}
+                  </div>
+                </details>
+              ))}
+            </div>
+          ) : null}
+
+          {linearResult ? (
