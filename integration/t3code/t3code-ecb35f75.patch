diff --git a/apps/web/src/components/chat/OrchestraLifecycleEntry.tsx b/apps/web/src/components/chat/OrchestraLifecycleEntry.tsx
new file mode 100644
index 00000000..ae5ac26f
--- /dev/null
+++ b/apps/web/src/components/chat/OrchestraLifecycleEntry.tsx
@@ -0,0 +1,162 @@
+import {
+  OrchestraReplayEvent,
+  type EnvironmentId,
+  type OrchestraEvidenceReference,
+  type OrchestraExecutionStepProjection,
+  type ThreadId,
+} from "@t3tools/contracts";
+import {
+  isAtomCommandInterrupted,
+  squashAtomCommandFailure,
+} from "@t3tools/client-runtime/state/runtime";
+import * as Schema from "effect/Schema";
+import { ChevronDownIcon, CircleAlertIcon, GitBranchIcon } from "lucide-react";
+import { memo, useCallback, useState } from "react";
+
+import { queryOrchestra } from "~/state/orchestra";
+import { useAtomCommand } from "~/state/use-atom-command";
+import { cn } from "~/lib/utils";
+import { Button } from "../ui/button";
+
+const isReplayEvent = Schema.is(OrchestraReplayEvent);
+
+export function readOrchestraReplayEvent(value: unknown): OrchestraReplayEvent | null {
+  return isReplayEvent(value) ? value : null;
+}
+
+function readableError(cause: unknown): string {
+  return cause instanceof Error ? cause.message : "Could not load Orchestra details.";
+}
+
+export const OrchestraLifecycleEntry = memo(function OrchestraLifecycleEntry(props: {
+  readonly environmentId: EnvironmentId;
+  readonly threadId: ThreadId;
+  readonly event: OrchestraReplayEvent;
+}) {
+  const { environmentId, threadId, event } = props;
+  const query = useAtomCommand(queryOrchestra, { reportFailure: false });
+  const [expanded, setExpanded] = useState(false);
+  const [loading, setLoading] = useState(false);
+  const [steps, setSteps] = useState<ReadonlyArray<OrchestraExecutionStepProjection> | null>(null);
+  const [evidence, setEvidence] = useState<ReadonlyArray<OrchestraEvidenceReference> | null>(null);
+  const [error, setError] = useState<string | null>(null);
+
+  const load = useCallback(
+    (selector: "steps" | "evidence") => {
+      setLoading(true);
+      setError(null);
+      void query({
+        environmentId,
+        input: {
+          threadId,
+          runId: event.runId,
+          selector,
+          maxItems: selector === "steps" ? 50 : 100,
+          maxBytes: 64 * 1024,
+        },
+      }).then((result) => {
+        setLoading(false);
+        if (result._tag === "Success") {
+          if (result.value.selector === "steps") setSteps(result.value.result.items);
+          else setEvidence(result.value.result.items);
+          return;
+        }
+        if (!isAtomCommandInterrupted(result)) {
+          setError(readableError(squashAtomCommandFailure(result)));
+        }
+      });
+    },
+    [environmentId, event.runId, query, threadId],
+  );
+
+  const toggle = useCallback(() => {
+    setExpanded((current) => {
+      const next = !current;
+      if (next && steps === null && !loading) load("steps");
+      return next;
+    });
+  }, [load, loading, steps]);
+
+  return (
+    <div className="rounded-md px-0.5 py-0.5">
+      <button
+        type="button"
+        className="flex w-full items-center gap-1.5 rounded text-left hover:bg-accent/20 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring/70"
+        aria-expanded={expanded}
+        onClick={toggle}
+      >
+        <span className="flex size-5 shrink-0 items-center justify-center text-muted-foreground/70">
+          <GitBranchIcon className="size-3.5" aria-hidden />
+        </span>
+        <span className="min-w-0 flex-1 truncate text-[12px] leading-5">
+          <span className="font-medium text-foreground/82">Orchestra workflow</span>
+          <span className="ms-1.5 text-muted-foreground/60">
+            {event.projection.status} · {event.kind}
+          </span>
+        </span>
+        <ChevronDownIcon
+          className={cn(
+            "size-3 text-muted-foreground transition-transform",
+            expanded && "rotate-180",
+          )}
+          aria-hidden
+        />
+      </button>
+
+      {expanded ? (
+        <div className="mt-1 ms-7 border-s border-border/45 ps-3 py-1 text-[11px] text-muted-foreground">
+          <div className="flex flex-wrap gap-x-3 gap-y-1">
+            <span>Run {event.runId}</span>
+            <span>Revision {event.revision}</span>
+            <span>{event.projection.nextAction}</span>
+          </div>
+
+          {loading && steps === null ? <p className="mt-2">Loading bounded step details…</p> : null}
+          {steps?.map((step) => (
+            <div key={step.id} className="mt-2 rounded border border-border/45 px-2 py-1.5">
+              <div className="flex flex-wrap items-center gap-x-2">
+                <span className="font-medium text-foreground/80">{step.id}</span>
+                <span>{step.status}</span>
+                <span>{step.outputCount} outputs</span>
+              </div>
+              {step.agent ? (
+                <div className="mt-1 font-mono text-[10px]">
+                  Child {step.agent.taskPath} · {step.agent.threadId}
+                </div>
+              ) : null}
+              {step.error ? (
+                <div className="mt-1 text-destructive">
+                  {step.error.text}
+                  {step.error.truncated ? "…" : ""}
+                </div>
+              ) : null}
+            </div>
+          ))}
+
+          <div className="mt-2 flex items-center gap-2">
+            <Button
+              size="sm"
+              variant="outline"
+              disabled={loading || evidence !== null}
+              onClick={() => load("evidence")}
+            >
+              {evidence === null ? "Load evidence references" : "Evidence references loaded"}
+            </Button>
+            <span>References only; artifact contents stay out of the timeline.</span>
+          </div>
+          {evidence?.map((item) => (
+            <div key={`${item.path}:${item.sha256 ?? ""}`} className="mt-1 font-mono text-[10px]">
+              {item.kind} · {item.path} · {item.bytes} bytes
+            </div>
+          ))}
+          {error ? (
+            <div className="mt-2 flex items-start gap-1.5 text-destructive">
+              <CircleAlertIcon className="mt-0.5 size-3 shrink-0" aria-hidden />
+              <span>{error}</span>
+            </div>
+          ) : null}
+        </div>
+      ) : null}
+    </div>
+  );
+});
