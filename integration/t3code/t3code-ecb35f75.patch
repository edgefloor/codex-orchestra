+  );
+
+  const inspectQueue = useCallback(
+    (category: AutomationQueueReadInput["category"], offset?: number) => {
+      if (!runResult) return;
+      setPending(true);
+      setError(null);
+      void readQueue({
+        environmentId,
+        input: {
+          threadId,
+          runId: runResult.run.runId,
+          category,
+          offset,
+          limit: 25,
+        },
