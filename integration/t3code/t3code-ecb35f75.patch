+              <div className="flex flex-wrap items-center gap-2">
+                <span className="text-sm font-medium">Linear intake</span>
+                <Badge variant="outline">{linearResult.status}</Badge>
+              </div>
+              {automationLinearRows(linearResult).map((issue) => (
+                <div key={issue.id} className="rounded-lg border bg-background p-3 text-xs">
+                  <div className="flex flex-wrap items-center gap-2">
+                    <span className="font-medium">{issue.identifier}</span>
+                    <Badge variant="secondary">{issue.state}</Badge>
+                    {issue.priority ? <span>priority {issue.priority}</span> : null}
+                  </div>
+                  <div className="mt-1 text-muted-foreground">{issue.title}</div>
+                  {issue.labels.length ? (
+                    <div className="mt-2 flex flex-wrap gap-1">
+                      {issue.labels.map((label) => (
+                        <Badge key={label} variant="outline">
+                          {label}
+                        </Badge>
+                      ))}
+                    </div>
+                  ) : null}
+                  {issue.blockedByCount ? (
+                    <div className="mt-2 text-muted-foreground">
+                      Blocked by {issue.blockedByCount} issue
+                      {issue.blockedByCount === 1 ? "" : "s"}
+                    </div>
+                  ) : null}
+                </div>
+              ))}
+              <div className="text-xs text-muted-foreground">
+                {linearResult.nextAction.text}
+                {linearResult.nextAction.truncated ? "…" : ""}
+              </div>
+            </div>
+          ) : null}
+        </DialogPanel>
+        <DialogFooter>
+          {result?.valid ? (
+            <>
+              <Button
+                disabled={pending}
+                onClick={() => readLinearIssues("candidates")}
+                variant="ghost"
+              >
+                Read active Linear
+              </Button>
+              <Button
+                disabled={pending}
+                onClick={() => readLinearIssues("terminal")}
+                variant="ghost"
+              >
+                Read terminal Linear
+              </Button>
+              <Button
+                disabled={pending}
+                onClick={() => readLinearIssues("refresh")}
+                variant="ghost"
+              >
+                Refresh issue
+              </Button>
+            </>
+          ) : null}
+          {runResult?.run.status === "running" ? (
+            <Button
+              disabled={pending}
+              onClick={() => runLifecycleAction("pause")}
+              variant="outline"
+            >
+              Pause
+            </Button>
+          ) : null}
+          {runResult && !["cancelled", "failed"].includes(runResult.run.status) ? (
+            <>
+              <Button
+                disabled={pending}
+                onClick={() => runLifecycleAction("status")}
+                variant="ghost"
+              >
+                Inspect
+              </Button>
+              <Button
+                disabled={pending}
+                onClick={() => runLifecycleAction("refresh")}
+                variant="ghost"
+              >
+                Refresh
+              </Button>
+            </>
+          ) : null}
+          {runResult?.run.status === "suspended" ? (
+            <Button
+              disabled={pending}
+              onClick={() => runLifecycleAction("resume")}
+              variant="outline"
+            >
+              Resume
+            </Button>
+          ) : null}
+          {runResult && !["cancelled", "failed"].includes(runResult.run.status) ? (
+            <Button disabled={pending} onClick={cancelRun} variant="destructive">
+              Cancel
+            </Button>
+          ) : null}
+          {result?.valid ? (
+            <Button disabled={pending} onClick={run} variant="outline">
