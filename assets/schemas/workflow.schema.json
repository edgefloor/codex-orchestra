{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-orchestra.local/schemas/workflow.schema.json",
  "title": "Codex Orchestra workflow",
  "type": "object",
  "required": ["schema_version", "name", "description", "limits", "steps"],
  "properties": {
    "schema_version": {"const": "1"},
    "name": {"type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$"},
    "description": {"type": "string", "minLength": 1},
    "inputs": {"type": "object", "additionalProperties": true},
    "limits": {
      "type": "object",
      "required": ["max_parallel", "max_steps", "max_attempts"],
      "properties": {
        "max_parallel": {"type": "integer", "minimum": 1, "maximum": 16},
        "max_steps": {"type": "integer", "minimum": 1, "maximum": 100},
        "max_attempts": {"type": "integer", "minimum": 1, "maximum": 5}
      },
      "additionalProperties": false
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/step"}
    }
  },
  "additionalProperties": false,
  "$defs": {
    "identifier": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
    "step": {
      "type": "object",
      "required": ["id", "type", "outputs"],
      "properties": {
        "id": {"$ref": "#/$defs/identifier"},
        "type": {"enum": ["agent", "check", "approval"]},
        "needs": {"type": "array", "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true},
        "agent": {"enum": ["planner", "worker", "reviewer", "verifier"]},
        "instructions": {"type": "string", "minLength": 1},
        "command": {"type": "string", "minLength": 1},
        "reason": {"type": "string", "minLength": 1},
        "default": {"type": "string", "minLength": 1},
        "when": {"type": "string", "minLength": 1},
        "workspace_from": {"$ref": "#/$defs/identifier"},
        "decisions": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {"enum": ["continue", "revise", "stop"]}
        },
        "read_only": {"type": "boolean"},
        "worktree": {"enum": ["shared", "isolated"]},
        "write_scope": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
        "outputs": {"type": "array", "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true},
        "max_attempts": {"type": "integer", "minimum": 1, "maximum": 5},
        "repeat": {
          "type": "object",
          "required": ["until", "max_rounds"],
          "properties": {
            "until": {"type": "string", "minLength": 1},
            "max_rounds": {"type": "integer", "minimum": 1, "maximum": 10},
            "stop_on_no_progress": {"type": "boolean"}
          },
          "additionalProperties": false
        }
      },
      "allOf": [
        {
          "if": {"properties": {"type": {"const": "agent"}}},
          "then": {"required": ["agent", "instructions", "read_only", "worktree", "write_scope", "max_attempts"]}
        },
        {
          "if": {"properties": {"type": {"const": "check"}}},
          "then": {"required": ["command"]}
        },
        {
          "if": {"properties": {"type": {"const": "approval"}}},
          "then": {"required": ["reason", "default", "decisions"]}
        }
      ],
      "additionalProperties": false
    }
  }
}
