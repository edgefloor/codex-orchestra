{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-orchestra.local/schemas/result.schema.json",
  "title": "Codex Orchestra step result",
  "type": "object",
  "required": ["step_id", "attempt", "status", "summary", "outputs", "changed_files", "evidence"],
  "properties": {
    "step_id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
    "attempt": {"type": "integer", "minimum": 1},
    "status": {"enum": ["complete", "failed", "blocked"]},
    "summary": {"type": "string", "minLength": 1},
    "outputs": {"type": "object"},
    "changed_files": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "evidence": {"type": "array", "items": {"type": "string"}},
    "residual_risks": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
