{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-orchestra.local/schemas/run-state.schema.json",
  "title": "Codex Orchestra workflow run state",
  "type": "object",
  "required": ["run_id", "workflow", "workflow_digest", "source_revision", "status", "steps", "updated_at"],
  "properties": {
    "run_id": {"type": "string", "minLength": 1},
    "workflow": {"type": "string", "const": "workflow.yaml"},
    "workflow_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "source_revision": {"type": "string", "minLength": 1},
    "status": {"enum": ["pending", "running", "waiting_approval", "blocked", "failed", "complete"]},
    "steps": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["status", "attempts"],
        "properties": {
          "status": {"enum": ["pending", "running", "waiting_approval", "blocked", "failed", "complete", "skipped"]},
          "attempts": {"type": "integer", "minimum": 0},
          "result": {"type": "string"},
          "decision": {"type": "string"},
          "outputs": {"type": "object"}
        },
        "additionalProperties": false
      }
    },
    "updated_at": {"type": "string", "format": "date-time"},
    "next_action": {"type": "string"}
  },
  "additionalProperties": false
}
