{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orchestra/task.schema.json",
  "title": "Task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "title",
    "workstream",
    "milestone",
    "scope_revision",
    "alignment_digest",
    "acceptance_criteria",
    "context_ref",
    "write_domain",
    "recommended_agent_type",
    "status"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "workstream": {
      "type": "string"
    },
    "milestone": {
      "type": "string"
    },
    "scope_revision": {
      "type": "integer",
      "minimum": 0
    },
    "alignment_digest": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "context_ref": {
      "type": "string",
      "minLength": 1
    },
    "write_domain": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_agent_type": {
      "type": "string"
    },
    "reports_to": {
      "type": "string"
    },
    "status": {
      "enum": [
        "draft",
        "ready",
        "in_progress",
        "in_review",
        "integrated",
        "done",
        "failed",
        "cancelled",
        "stale"
      ]
    }
  }
}
