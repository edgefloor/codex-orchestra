{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orchestra/portfolio-checkpoint.schema.json",
  "title": "Manager Portfolio Checkpoint",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "message_type",
    "message_id",
    "project_id",
    "phase",
    "milestone",
    "scope_revision",
    "alignment_digest",
    "sender",
    "summary",
    "workstreams",
    "open_decision_refs",
    "drift_alert_refs",
    "assurance_status",
    "resource_totals",
    "recommendation",
    "evidence_refs",
    "requested_action"
  ],
  "properties": {
    "message_type": {"const": "portfolio_checkpoint"},
    "message_id": {"type": "string", "minLength": 4},
    "project_id": {"type": "string", "minLength": 1},
    "phase": {
      "enum": ["NEW", "GROUNDING", "PLANNING", "ORGANIZING", "EXECUTING", "VERIFYING", "ACCEPTANCE", "DONE", "PAUSED", "REGROUNDING"]
    },
    "milestone": {"type": "string", "minLength": 1},
    "scope_revision": {"type": "integer", "minimum": 0},
    "alignment_digest": {"type": "string", "pattern": "^sha256:[a-fA-F0-9]{64}$"},
    "sender": {"type": "string", "minLength": 1},
    "summary": {"type": "string", "minLength": 1, "maxLength": 1800},
    "workstreams": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "owner", "health", "active_capacity", "capacity_limit", "organizational_consequence"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "owner": {"type": "string", "minLength": 1},
          "health": {"enum": ["on_track", "at_risk", "blocked", "paused", "complete"]},
          "active_capacity": {"type": "integer", "minimum": 0},
          "capacity_limit": {"type": "integer", "minimum": 0},
          "organizational_consequence": {"type": ["string", "null"]},
          "branch_report_ref": {"type": ["string", "null"]}
        }
      }
    },
    "open_decision_refs": {"type": "array", "items": {"type": "string"}},
    "drift_alert_refs": {"type": "array", "items": {"type": "string"}},
    "assurance_status": {"type": "string", "minLength": 1, "maxLength": 600},
    "resource_totals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["active_threads", "reserved_control_threads", "reserved_verification_threads", "retries"],
      "properties": {
        "active_threads": {"type": "integer", "minimum": 0},
        "reserved_control_threads": {"type": "integer", "minimum": 0},
        "reserved_verification_threads": {"type": "integer", "minimum": 0},
        "retries": {"type": "integer", "minimum": 0}
      }
    },
    "recommendation": {
      "enum": ["continue", "pause", "rebalance", "replan", "reground", "advance_phase", "request_operator_decision", "no_action"]
    },
    "evidence_refs": {"type": "array", "items": {"type": "string"}, "maxItems": 50},
    "requested_action": {"type": "string", "minLength": 1}
  }
}
