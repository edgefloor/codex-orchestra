{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orchestra/verification-result.schema.json",
  "title": "Verification Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "message_type",
    "message_id",
    "project_id",
    "task_id",
    "scope_revision",
    "alignment_digest",
    "sender",
    "summary",
    "environment",
    "checks",
    "findings",
    "source_modified",
    "requested_action",
    "confidence"
  ],
  "properties": {
    "message_type": {
      "const": "verification_result"
    },
    "message_id": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "scope_revision": {
      "type": "integer"
    },
    "alignment_digest": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "sender": {
      "type": "string"
    },
    "summary": {
      "type": "string",
      "maxLength": 1000
    },
    "environment": {
      "type": "object"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "gate_id",
          "command_or_method",
          "status",
          "evidence_refs"
        ],
        "properties": {
          "gate_id": {
            "type": "string"
          },
          "command_or_method": {
            "type": "string"
          },
          "status": {
            "enum": [
              "pass",
              "fail",
              "blocked",
              "not_applicable"
            ]
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "source_modified": {
      "const": false
    },
    "requested_action": {
      "type": "string"
    },
    "confidence": {
      "enum": [
        "low",
        "medium",
        "high"
      ]
    }
  }
}
