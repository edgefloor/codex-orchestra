{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orchestra/branch-report.schema.json",
  "title": "Bounded Branch Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "message_type", "message_id", "project_id", "sender_path", "parent_path",
    "scope_revision", "alignment_digest", "permit_ref", "status", "summary",
    "completed_refs", "key_findings", "evidence_refs", "capacity_effect",
    "decision_requests", "residual_risks", "requested_action"
  ],
  "properties": {
    "message_type": {"const": "branch_report"},
    "message_id": {"type": "string"},
    "project_id": {"type": "string"},
    "sender_path": {"type": "string"},
    "parent_path": {"type": "string"},
    "scope_revision": {"type": "integer", "minimum": 0},
    "alignment_digest": {"type": "string", "pattern": "^sha256:[a-fA-F0-9]{64}$"},
    "permit_ref": {"type": "string"},
    "status": {"enum": ["completed", "checkpoint", "blocked", "failed", "cancelled"]},
    "summary": {"type": "string", "minLength": 1, "maxLength": 1800},
    "completed_refs": {"type": "array", "items": {"type": "string"}},
    "key_findings": {"type": "array", "maxItems": 5, "items": {"type": "string"}},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "capacity_effect": {
      "type": "object", "additionalProperties": false,
      "required": ["released_slots", "continuing_seats", "requested_delta"],
      "properties": {
        "released_slots": {"type": "integer", "minimum": 0},
        "continuing_seats": {"type": "array", "items": {"type": "string"}},
        "requested_delta": {"type": "integer"}
      }
    },
    "decision_requests": {"type": "array", "items": {"type": "string"}},
    "residual_risks": {"type": "array", "items": {"type": "string"}},
    "requested_action": {"type": "string", "minLength": 1}
  }
}
