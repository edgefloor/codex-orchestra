{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orchestra/tactical-plan.schema.json",
  "title": "Tactical Execution Wave",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "message_type",
    "message_id",
    "project_id",
    "workstream",
    "milestone",
    "scope_revision",
    "alignment_digest",
    "wave_id",
    "team_leader",
    "tasks",
    "integration_order",
    "hire_requests",
    "risks",
    "requested_action",
    "workflow_shape",
    "fanout_budget",
    "join_owner",
    "checkpoint_after",
    "delegation_permit_ref",
    "review_policy"
  ],
  "properties": {
    "message_type": {
      "const": "tactical_plan"
    },
    "message_id": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "workstream": {
      "type": "string"
    },
    "milestone": {
      "type": "string"
    },
    "scope_revision": {
      "type": "integer"
    },
    "alignment_digest": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "wave_id": {
      "type": "string"
    },
    "team_leader": {
      "type": "string"
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "task_id",
          "outcome",
          "depends_on",
          "acceptance_criteria",
          "write_domain",
          "recommended_agent_type",
          "keep_by_team_leader"
        ],
        "properties": {
          "task_id": {
            "type": "string"
          },
          "outcome": {
            "type": "string"
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "acceptance_criteria": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "write_domain": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "recommended_agent_type": {
            "type": "string"
          },
          "keep_by_team_leader": {
            "type": "boolean"
          }
        }
      }
    },
    "integration_order": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "hire_requests": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requested_action": {
      "type": "string"
    },
    "workflow_shape": {
      "enum": [
        "single_owner",
        "parallel_map",
        "sequential_pipeline",
        "review_loop",
        "fanout_verify"
      ]
    },
    "fanout_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_new_agents",
        "max_concurrency",
        "reserved_review_slots"
      ],
      "properties": {
        "max_new_agents": {
          "type": "integer",
          "minimum": 0,
          "maximum": 12
        },
        "max_concurrency": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3
        },
        "reserved_review_slots": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2
        }
      }
    },
    "join_owner": {
      "type": "string"
    },
    "checkpoint_after": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "delegation_permit_ref": {
      "type": "string",
      "minLength": 1
    },
    "review_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "independent_review_triggers",
        "reviewer_archetype",
        "no_findings_required"
      ],
      "properties": {
        "independent_review_triggers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reviewer_archetype": {
          "enum": [
            "reviewer_terra",
            "advisor_sol",
            "none"
          ]
        },
        "no_findings_required": {
          "type": "boolean"
        }
      }
    }
  }
}
