{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orchestra/decision-request.schema.json",
  "title": "Decision Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "message_type",
    "message_id",
    "project_id",
    "scope_revision",
    "alignment_digest",
    "sender",
    "decision",
    "outside_sender_authority",
    "options",
    "recommendation",
    "default_if_deadline_passes",
    "deadline",
    "affected_refs",
    "evidence_refs",
    "requested_action"
  ],
  "properties": {
    "message_type": {
      "const": "decision_request"
    },
    "message_id": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "scope_revision": {
      "type": "integer"
    },
    "alignment_digest": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "sender": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "minLength": 1
    },
    "outside_sender_authority": {
      "type": "string",
      "minLength": 1
    },
    "options": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "tradeoff"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "tradeoff": {
            "type": "string"
          },
          "consequences": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "recommendation": {
      "type": "string",
      "minLength": 1
    },
    "default_if_deadline_passes": {
      "type": [
        "string",
        "null"
      ]
    },
    "deadline": {
      "type": "string",
      "format": "date-time"
    },
    "affected_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requested_action": {
      "type": "string"
    }
  }
}
