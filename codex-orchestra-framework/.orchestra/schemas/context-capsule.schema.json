{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orchestra/context-capsule.schema.json",
  "title": "Context Capsule",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "identity",
    "assignment",
    "boundaries",
    "constraints",
    "interfaces",
    "context",
    "execution",
    "validation",
    "escalation",
    "output",
    "budget"
  ],
  "properties": {
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capsule_id",
        "task_id",
        "project_id",
        "scope_revision",
        "alignment_digest",
        "delegation_permit_ref",
        "role_card_ref"
      ],
      "properties": {
        "capsule_id": {
          "type": "string"
        },
        "task_id": {
          "type": "string"
        },
        "project_id": {
          "type": "string"
        },
        "scope_revision": {
          "type": "integer",
          "minimum": 0
        },
        "alignment_digest": {
          "type": "string",
          "pattern": "^sha256:[a-fA-F0-9]{64}$"
        },
        "delegation_permit_ref": {
          "type": "string",
          "minLength": 1
        },
        "role_card_ref": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "assignment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "goal",
        "definition_of_done",
        "deliverables"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "definition_of_done": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "deliverables": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "boundaries": {
      "type": "object",
      "required": [
        "writable_paths",
        "forbidden_paths",
        "non_goals"
      ],
      "properties": {
        "writable_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbidden_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "non_goals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "interfaces": {
      "type": "object",
      "required": [
        "consumes",
        "produces"
      ],
      "properties": {
        "consumes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "produces": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "context": {
      "type": "object",
      "required": [
        "must_read",
        "read_on_demand"
      ],
      "properties": {
        "must_read": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ref"
          }
        },
        "read_on_demand": {
          "type": "array",
          "items": {
            "allOf": [
              {
                "$ref": "#/$defs/ref"
              },
              {
                "type": "object",
                "required": [
                  "trigger"
                ]
              }
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "validation": {
      "type": "object",
      "required": [
        "commands",
        "evidence_required"
      ],
      "properties": {
        "commands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence_required": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "escalation": {
      "type": "object",
      "required": [
        "reports_to",
        "decision_authority",
        "default_when_reversible"
      ],
      "properties": {
        "reports_to": {
          "type": "string"
        },
        "decision_authority": {
          "type": "string"
        },
        "default_when_reversible": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "output": {
      "type": "object",
      "required": [
        "schema_ref",
        "artifact_directory"
      ],
      "properties": {
        "schema_ref": {
          "type": "string"
        },
        "artifact_directory": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "budget": {
      "type": "object",
      "required": [
        "target_input_tokens",
        "max_summary_words",
        "max_tool_calls",
        "max_child_agents"
      ],
      "properties": {
        "target_input_tokens": {
          "type": "integer",
          "minimum": 1000
        },
        "max_summary_words": {
          "type": "integer",
          "minimum": 50,
          "maximum": 1000
        },
        "max_tool_calls": {
          "type": "integer",
          "minimum": 1
        },
        "max_child_agents": {
          "const": 0
        }
      },
      "additionalProperties": false
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "base_revision",
        "worktree_ref",
        "dependencies",
        "stop_conditions"
      ],
      "properties": {
        "base_revision": {
          "type": "string",
          "minLength": 1
        },
        "worktree_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stop_conditions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "ref": {
      "type": "object",
      "required": [
        "ref",
        "why"
      ],
      "properties": {
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "why": {
          "type": "string",
          "minLength": 1
        },
        "trigger": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
