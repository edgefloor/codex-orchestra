{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orchestra/gate-report.schema.json",
  "title": "Gate Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "message_type",
    "message_id",
    "project_id",
    "milestone_id",
    "scope_revision",
    "alignment_digest",
    "verdict",
    "summary",
    "gates",
    "waivers",
    "residual_risks",
    "requested_action"
  ],
  "properties": {
    "message_type": {
      "const": "gate_report"
    },
    "message_id": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "milestone_id": {
      "type": "string"
    },
    "scope_revision": {
      "type": "integer"
    },
    "alignment_digest": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "verdict": {
      "enum": [
        "pass",
        "conditional_pass",
        "fail"
      ]
    },
    "summary": {
      "type": "string"
    },
    "gates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "gate_id",
          "status",
          "evidence_refs",
          "finding_refs"
        ],
        "properties": {
          "gate_id": {
            "type": "string"
          },
          "status": {
            "enum": [
              "pass",
              "fail",
              "waived",
              "not_applicable"
            ]
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "finding_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "waivers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "residual_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requested_action": {
      "type": "string"
    }
  }
}
