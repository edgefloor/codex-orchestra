{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orchestra/delegation-permit.schema.json",
  "title": "Delegation Permit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "permit_id", "project_id", "issued_by", "parent_path", "parent_role",
    "scope_revision", "alignment_digest", "purpose_refs", "allowed_child_types",
    "budget", "write_policy", "valid_from", "expires_at", "stop_conditions", "status"
  ],
  "properties": {
    "permit_id": {"type": "string", "minLength": 4},
    "project_id": {"type": "string"},
    "issued_by": {"type": "string"},
    "parent_path": {"type": "string", "pattern": "^/root(?:/[a-z0-9_]+)*$"},
    "parent_role": {"type": "string"},
    "scope_revision": {"type": "integer", "minimum": 0},
    "alignment_digest": {"type": "string", "pattern": "^sha256:[a-fA-F0-9]{64}$"},
    "purpose_refs": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "allowed_child_types": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
    "allowed_task_refs": {"type": "array", "items": {"type": "string"}},
    "budget": {
      "type": "object", "additionalProperties": false,
      "required": ["max_children", "max_concurrency", "max_total_attempts", "token_or_time_class"],
      "properties": {
        "max_children": {"type": "integer", "minimum": 1, "maximum": 12},
        "max_concurrency": {"type": "integer", "minimum": 1, "maximum": 10},
        "max_total_attempts": {"type": "integer", "minimum": 1, "maximum": 24},
        "token_or_time_class": {"enum": ["small", "standard", "large", "exceptional"]}
      }
    },
    "write_policy": {
      "type": "object", "additionalProperties": false,
      "required": ["max_parallel_writers", "require_worktree", "allowed_domains"],
      "properties": {
        "max_parallel_writers": {"type": "integer", "minimum": 0, "maximum": 4},
        "require_worktree": {"type": "boolean"},
        "allowed_domains": {"type": "array", "items": {"type": "string"}}
      }
    },
    "valid_from": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"},
    "stop_conditions": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "exception_authorization_ref": {"type": ["string", "null"]},
    "status": {"enum": ["proposed", "active", "exhausted", "revoked", "expired"]}
  }
}
