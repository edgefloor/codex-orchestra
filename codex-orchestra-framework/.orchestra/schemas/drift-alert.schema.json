{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orchestra/drift-alert.schema.json",
  "title": "Drift Alert",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "message_type",
    "message_id",
    "project_id",
    "scope_revision",
    "alignment_digest",
    "sender",
    "observed_evidence",
    "conflicting_source_ref",
    "classification",
    "blast_radius",
    "affected_refs",
    "proposed_owner",
    "recommended_route",
    "safe_unaffected_work",
    "requested_action"
  ],
  "properties": {
    "message_type": {
      "const": "drift_alert"
    },
    "message_id": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "scope_revision": {
      "type": "integer"
    },
    "alignment_digest": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "sender": {
      "type": "string"
    },
    "observed_evidence": {
      "type": "string",
      "minLength": 1
    },
    "conflicting_source_ref": {
      "type": "string",
      "minLength": 1
    },
    "classification": {
      "enum": [
        "local_defect",
        "tactical_plan_error",
        "delivery_plan_error",
        "grounding_or_assurance_change"
      ]
    },
    "blast_radius": {
      "enum": [
        "task",
        "workstream",
        "milestone",
        "project"
      ]
    },
    "affected_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "proposed_owner": {
      "type": "string"
    },
    "recommended_route": {
      "type": "string"
    },
    "safe_unaffected_work": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requested_action": {
      "type": "string"
    }
  }
}
