{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orchestra/staffing-decision.schema.json",
  "title": "Staffing Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "message_type",
    "message_id",
    "project_id",
    "scope_revision",
    "alignment_digest",
    "sender",
    "summary",
    "decision",
    "assignments",
    "capacity_changes",
    "hire_request_refs",
    "constraints_for_delegate",
    "follow_up_owner",
    "requested_action",
    "delegation_permit_refs",
    "physical_parent_assignments"
  ],
  "properties": {
    "message_type": {
      "const": "staffing_decision"
    },
    "message_id": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "scope_revision": {
      "type": "integer",
      "minimum": 0
    },
    "alignment_digest": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "sender": {
      "type": "string"
    },
    "summary": {
      "type": "string",
      "maxLength": 1000
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "rationale",
        "effective_at"
      ],
      "properties": {
        "kind": {
          "enum": [
            "appoint_owner",
            "hire",
            "reject_hire",
            "release",
            "rebalance",
            "priority",
            "pause",
            "continue",
            "replan",
            "reground"
          ]
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "effective_at": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "assignments": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "capacity_changes": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "hire_request_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "constraints_for_delegate": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "follow_up_owner": {
      "type": "string"
    },
    "requested_action": {
      "type": "string"
    },
    "delegation_permit_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "physical_parent_assignments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "child_role",
          "parent_path"
        ],
        "properties": {
          "child_role": {
            "type": "string"
          },
          "parent_path": {
            "type": "string"
          }
        }
      }
    }
  }
}
