{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orchestra/delivery-plan.schema.json",
  "title": "Delivery Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "message_type",
    "project_id",
    "scope_revision",
    "alignment_digest",
    "milestones",
    "workstreams",
    "integration_strategy",
    "assumptions",
    "requested_action"
  ],
  "properties": {
    "message_type": {
      "const": "delivery_plan"
    },
    "project_id": {
      "type": "string"
    },
    "scope_revision": {
      "type": "integer"
    },
    "alignment_digest": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "milestones": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "outcome",
          "depends_on",
          "workstreams",
          "acceptance",
          "evidence_expectations"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "outcome": {
            "type": "string"
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "workstreams": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "acceptance": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "evidence_expectations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "risks_retired": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "workstreams": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "mission",
          "owns",
          "consumes",
          "produces",
          "integration_boundary"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "mission": {
            "type": "string"
          },
          "owns": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "consumes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "produces": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "integration_boundary": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "integration_strategy": {
      "type": "string",
      "minLength": 1
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requested_action": {
      "type": "string"
    }
  }
}
