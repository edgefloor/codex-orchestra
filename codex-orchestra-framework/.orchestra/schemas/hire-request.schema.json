{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orchestra/hire-request.schema.json",
  "title": "Hire Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "message_type",
    "request_id",
    "requester",
    "reports_to",
    "capability_gap",
    "outcomes_unlocked",
    "why_current_team_cannot_absorb",
    "expected_lifetime",
    "urgency",
    "cost_of_delay",
    "access_requirements",
    "tasks_or_milestones",
    "requester_path",
    "physical_parent_path",
    "required_outcomes",
    "delegation_budget_needed"
  ],
  "properties": {
    "message_type": {
      "const": "hire_request"
    },
    "request_id": {
      "type": "string"
    },
    "requester": {
      "type": "string"
    },
    "reports_to": {
      "type": "string"
    },
    "capability_gap": {
      "type": "string",
      "minLength": 1
    },
    "outcomes_unlocked": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "why_current_team_cannot_absorb": {
      "type": "string",
      "minLength": 1
    },
    "expected_lifetime": {
      "enum": [
        "one_task",
        "milestone",
        "recurring"
      ]
    },
    "estimated_utilization": {
      "type": [
        "string",
        "number"
      ]
    },
    "urgency": {
      "enum": [
        "normal",
        "critical_path"
      ]
    },
    "cost_of_delay": {
      "type": "string",
      "minLength": 1
    },
    "access_requirements": {
      "type": "object",
      "required": [
        "sandbox",
        "tools",
        "data_classification"
      ],
      "properties": {
        "sandbox": {
          "enum": [
            "read-only",
            "workspace-write",
            "danger-full-access"
          ]
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "data_classification": {
          "enum": [
            "public",
            "internal",
            "confidential",
            "restricted"
          ]
        }
      },
      "additionalProperties": false
    },
    "independence_constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "suggested_archetype": {
      "type": [
        "string",
        "null"
      ]
    },
    "tasks_or_milestones": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "requester_path": {
      "type": "string",
      "pattern": "^/root(?:/[a-z0-9_]+)*$"
    },
    "physical_parent_path": {
      "type": "string",
      "pattern": "^/root(?:/[a-z0-9_]+)*$"
    },
    "required_outcomes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "delegation_budget_needed": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "seat_count",
        "max_concurrency",
        "expected_attempts"
      ],
      "properties": {
        "seat_count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4
        },
        "max_concurrency": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4
        },
        "expected_attempts": {
          "type": "integer",
          "minimum": 1,
          "maximum": 8
        }
      }
    }
  }
}
