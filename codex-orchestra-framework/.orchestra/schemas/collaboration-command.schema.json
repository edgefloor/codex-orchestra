{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orchestra/collaboration-command.schema.json",
  "title": "Codex V2 Collaboration Command or Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "command_id",
    "action",
    "actor_path",
    "actor_role",
    "reason",
    "created_at"
  ],
  "properties": {
    "command_id": {
      "type": "string",
      "minLength": 4
    },
    "action": {
      "enum": [
        "spawn",
        "queue_message",
        "wake",
        "wait",
        "interrupt",
        "reconcile",
        "receipt"
      ]
    },
    "actor_path": {
      "type": "string",
      "pattern": "^/root(?:/[a-z0-9_]+)*$"
    },
    "actor_role": {
      "type": "string"
    },
    "parent_path": {
      "type": "string",
      "pattern": "^/root(?:/[a-z0-9_]+)*$"
    },
    "target": {
      "type": "string"
    },
    "task_name": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "agent_type": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "reasoning_effort": {
      "enum": [
        "low",
        "medium",
        "high",
        "xhigh",
        "max",
        "ultra"
      ]
    },
    "fork_turns": {
      "oneOf": [
        {
          "enum": [
            "none",
            "all"
          ]
        },
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "pattern": "^[1-9][0-9]*$"
        }
      ]
    },
    "message_ref": {
      "type": "string"
    },
    "delegation_permit_ref": {
      "type": "string"
    },
    "role_card_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "context_capsule_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "timeout_ms": {
      "type": "integer",
      "minimum": 1000,
      "maximum": 300000
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "budget_reservation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "thread_slots",
        "max_children",
        "token_or_time_class"
      ],
      "properties": {
        "thread_slots": {
          "type": "integer",
          "minimum": 0
        },
        "max_children": {
          "type": "integer",
          "minimum": 0
        },
        "token_or_time_class": {
          "enum": [
            "small",
            "standard",
            "large",
            "exceptional"
          ]
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "exception_authorization_ref": {
      "type": "string",
      "minLength": 1
    },
    "receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "agent_path"
      ],
      "properties": {
        "status": {
          "enum": [
            "accepted",
            "started",
            "completed",
            "errored",
            "interrupted",
            "rejected"
          ]
        },
        "agent_path": {
          "type": "string"
        },
        "result_ref": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "action": {
            "const": "spawn"
          }
        },
        "required": [
          "action"
        ]
      },
      "then": {
        "required": [
          "parent_path",
          "task_name",
          "fork_turns",
          "message_ref",
          "delegation_permit_ref",
          "budget_reservation"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "action": {
            "enum": [
              "queue_message",
              "wake",
              "interrupt"
            ]
          }
        },
        "required": [
          "action"
        ]
      },
      "then": {
        "required": [
          "target"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "action": {
            "enum": [
              "queue_message",
              "wake"
            ]
          }
        },
        "required": [
          "action"
        ]
      },
      "then": {
        "required": [
          "message_ref"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "action": {
            "const": "wait"
          }
        },
        "required": [
          "action"
        ]
      },
      "then": {
        "required": [
          "timeout_ms"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "action": {
            "const": "receipt"
          }
        },
        "required": [
          "action"
        ]
      },
      "then": {
        "required": [
          "receipt"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "action": {
            "const": "spawn"
          },
          "fork_turns": {
            "not": {
              "const": "all"
            }
          }
        },
        "required": [
          "action",
          "fork_turns"
        ]
      },
      "then": {
        "required": [
          "agent_type",
          "model",
          "reasoning_effort"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "reasoning_effort": {
            "const": "ultra"
          }
        },
        "required": [
          "reasoning_effort"
        ]
      },
      "then": {
        "required": [
          "exception_authorization_ref",
          "budget_reservation"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "action": {
            "const": "spawn"
          },
          "fork_turns": {
            "const": "all"
          }
        },
        "required": [
          "action",
          "fork_turns"
        ]
      },
      "then": {
        "required": [
          "exception_authorization_ref"
        ],
        "not": {
          "anyOf": [
            {
              "required": [
                "agent_type"
              ]
            },
            {
              "required": [
                "model"
              ]
            },
            {
              "required": [
                "reasoning_effort"
              ]
            }
          ]
        }
      }
    }
  ]
}
