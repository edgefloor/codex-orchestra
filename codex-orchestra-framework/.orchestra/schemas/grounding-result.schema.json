{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orchestra/grounding-result.schema.json",
  "title": "Grounding Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "message_type",
    "message_id",
    "project_id",
    "proposed_scope_revision",
    "sender",
    "summary",
    "brief_ref",
    "scope_ref",
    "assurance_ref",
    "acceptance_scenarios",
    "assumptions",
    "open_decisions",
    "grounding_gate",
    "requested_action"
  ],
  "properties": {
    "message_type": {
      "const": "grounding_result"
    },
    "message_id": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "proposed_scope_revision": {
      "type": "integer",
      "minimum": 1
    },
    "sender": {
      "type": "string"
    },
    "summary": {
      "type": "string",
      "maxLength": 1000
    },
    "brief_ref": {
      "type": "string"
    },
    "scope_ref": {
      "type": "string"
    },
    "assurance_ref": {
      "type": "string"
    },
    "acceptance_scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "open_decisions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "grounding_gate": {
      "enum": [
        "pass",
        "needs_operator_decision",
        "fail"
      ]
    },
    "requested_action": {
      "type": "string"
    }
  }
}
