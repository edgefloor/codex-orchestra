{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orchestra/assurance-profile.schema.json",
  "title": "Assurance Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "scope_revision",
    "profile",
    "caveats",
    "accepted_risks"
  ],
  "properties": {
    "status": {
      "enum": [
        "draft",
        "accepted",
        "superseded"
      ]
    },
    "scope_revision": {
      "type": "integer",
      "minimum": 0
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maturity",
        "data_sensitivity",
        "blast_radius",
        "reversibility",
        "availability",
        "compliance"
      ],
      "properties": {
        "maturity": {
          "enum": [
            "spike",
            "prototype",
            "beta",
            "production",
            "regulated"
          ]
        },
        "data_sensitivity": {
          "enum": [
            "public",
            "internal",
            "confidential",
            "restricted"
          ]
        },
        "blast_radius": {
          "enum": [
            "local",
            "team",
            "customer",
            "platform"
          ]
        },
        "reversibility": {
          "enum": [
            "easy",
            "migration",
            "irreversible"
          ]
        },
        "availability": {
          "enum": [
            "none",
            "standard",
            "critical"
          ]
        },
        "compliance": {
          "enum": [
            "none",
            "policy",
            "regulatory"
          ]
        }
      }
    },
    "caveats": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "accepted_risks": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "mandatory_external_standards": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "waiver_authorities": {
      "type": "object"
    }
  }
}
