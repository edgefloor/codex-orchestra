{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orchestra/result-envelope.schema.json",
  "title": "Task Result Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "message_type",
    "message_id",
    "project_id",
    "task_id",
    "attempt_id",
    "scope_revision",
    "alignment_digest",
    "sender",
    "summary",
    "status",
    "no_findings",
    "key_findings",
    "deliverable_refs",
    "change_refs",
    "evidence_refs",
    "acceptance",
    "assumptions",
    "residual_risks",
    "requested_action",
    "confidence"
  ],
  "properties": {
    "message_type": {
      "const": "result"
    },
    "message_id": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "attempt_id": {
      "type": "string"
    },
    "scope_revision": {
      "type": "integer",
      "minimum": 0
    },
    "alignment_digest": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "sender": {
      "type": "string"
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "status": {
      "enum": [
        "completed",
        "partial",
        "failed"
      ]
    },
    "deliverable_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "change_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "criterion",
          "status",
          "evidence_refs"
        ],
        "properties": {
          "criterion": {
            "type": "string"
          },
          "status": {
            "enum": [
              "pass",
              "fail",
              "not_run"
            ]
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "residual_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requested_action": {
      "type": "string"
    },
    "confidence": {
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "no_findings": {
      "type": "boolean"
    },
    "key_findings": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "finding",
          "evidence_refs",
          "recommended_action"
        ],
        "properties": {
          "severity": {
            "enum": [
              "critical",
              "high",
              "medium",
              "low",
              "note"
            ]
          },
          "finding": {
            "type": "string",
            "minLength": 1
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "recommended_action": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "no_findings": {
            "const": true
          }
        },
        "required": [
          "no_findings"
        ]
      },
      "then": {
        "properties": {
          "key_findings": {
            "maxItems": 0
          }
        }
      }
    }
  ]
}
